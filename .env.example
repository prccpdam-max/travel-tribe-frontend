# =============================================
# Travel Tribe — Frontend Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าให้ครบ
# =============================================

# ---- API URL ----
# ทดสอบ local: ใช้ IP จริงของเครื่อง ไม่ใช่ localhost
# (เพราะมือถือต้องเชื่อมต่อผ่าน WiFi เดียวกัน)
EXPO_PUBLIC_API_URL=http://192.168.1.100:3000/api

# Production: เปลี่ยนเป็น URL จริง
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api

# ---- Firebase (Web App Config) ----
# หาได้จาก: Firebase Console → Project Settings → Your apps → </> (Web)
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# ---- Google Sign-In ----
# หาได้จาก: Firebase Console → Authentication → Sign-in method → Google → Web client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
